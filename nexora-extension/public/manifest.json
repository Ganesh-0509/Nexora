{
  "manifest_version": 3,
  "name": "Nexora — AI Application Assistant",
  "short_name": "Nexora",
  "version": "1.0.0",
  "description": "AI-powered autofill, resume matching, and application assistance for students.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "identity"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://jobs.lever.co/*",
    "https://boards.greenhouse.io/*",
    "https://wellfound.com/*",
    "https://internshala.com/*",
    "https://www.ycombinator.com/*",
    "https://myworkdayjobs.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://jobs.lever.co/*",
        "https://boards.greenhouse.io/*",
        "https://wellfound.com/jobs/*",
        "https://internshala.com/*",
        "https://www.ycombinator.com/jobs/*",
        "https://*.myworkdayjobs.com/*"
      ],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Nexora Assistant",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["overlay.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
